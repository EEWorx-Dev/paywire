{
  "name": "paywire",
  "version": "1.0.0",
  "description": "Type-safe, format-agnostic library for financial payment messages (ISO 8583, hex, XML, JSON, and more)",
  "keywords": ["iso8583", "payment", "financial", "message", "iso", "8583", "banking"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0"
  }
}

